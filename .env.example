# ============================================================
# Fairtrail — Self-Hosted Configuration
# ============================================================
# Copy this file: cp .env.example .env
# Then edit the values below.
#
# Only ONE LLM provider API key is required — pick whichever you have.
# ============================================================

# --- Database (defaults work with docker compose) ---
POSTGRES_PASSWORD=postgres
# DATABASE_URL is set automatically by docker-compose.yml
# Only set this if running without Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fairtrail

# --- Cache (optional — comment out to disable) ---
# REDIS_URL is set automatically by docker-compose.yml
# Only set this if running without Docker:
# REDIS_URL=redis://localhost:6379

# --- LLM Provider (at least one required) ---
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# Optional: point to an OpenAI-compatible endpoint (OpenRouter, llama.cpp, Ollama, vLLM, etc.)
# When set, you can type any model ID in the admin config (e.g. llama-3.1-70b, mixtral-8x7b).
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Google AI — https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=

# Claude Code and Codex CLIs are auto-detected when their binaries are installed
# and host auth is mounted (~/.claude, ~/.codex via docker-compose volumes).
# API key users should use the SDK providers above instead.

# --- Admin ---
# Leave empty for auto-generation on first run (printed in logs)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
CRON_SECRET=

# --- Community Data Sharing (opt-in) ---
# URL of the central Fairtrail hub for aggregated price data
# COMMUNITY_HUB_URL=https://fairtrail.org

# --- Cron (built-in scheduler) ---
# Set to false to disable built-in scrape scheduler (e.g., if using external cron)
# CRON_ENABLED=true
# CRON_INTERVAL_HOURS=3

# --- Port (default: 3003) ---
# Host port to access Fairtrail (the container always listens on 3003 internally)
# PORT=3003
